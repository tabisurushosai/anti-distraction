{
  "name": "anti-distraction",
  "version": "1.0.0",
  "description": "SNS/YouTube tab gray-out and time limit Chrome extension (Manifest V3)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "lint": "tsc --noEmit",
    "test": "node --test tests/**/*.test.mjs",
    "test:run": "node --test tests/**/*.test.mjs",
    "check:release-config": "node scripts/check-release-config.mjs",
    "audit:package": "node scripts/audit-package.mjs",
    "package": "npm run check:release-config && npm run build && node scripts/package.mjs && npm run audit:package",
    "audit:i18n": "node scripts/audit-i18n.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  }
}
